{
  "version": 2,
  "builds": [
    { "src": "api/chat.js", "use": "@vercel/node" },
    { "src": "api/clients.js", "use": "@vercel/node" },
    { "src": "api/evaluate.js", "use": "@vercel/node" },
    { "src": "api/modules.js", "use": "@vercel/node" },
    { "src": "api/simulations.js", "use": "@vercel/node" },
    { "src": "api/tts.js", "use": "@vercel/node" },
    { "src": "api/auth/config.js", "use": "@vercel/node" },
    { "src": "api/auth/google.js", "use": "@vercel/node" },
    { "src": "api/auth/signin.js", "use": "@vercel/node" },
    { "src": "api/auth/me.js", "use": "@vercel/node" },
    { "src": "api/admin/users.js", "use": "@vercel/node" },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
